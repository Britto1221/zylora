ENVIRONMENT=development
APP_NAME=Zylora

# Development uses SQLite by default. Set PostgreSQL here to match production locally.
DATABASE_URL=sqlite:///./zylora-dev.db
REDIS_URL=redis://localhost:6379/0
WEB_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000/api/v1
API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local development authentication only
DEV_AUTH_SECRET=zylora-development-secret-change-me
DEV_ADMIN_PASSWORD=zylora-admin
SUPER_ADMIN_EMAILS=admin@zylora.dev
AUTH_ISSUER=
AUTH_AUDIENCE=zylora-api
AUTH_JWKS_URL=
AUTH_ALGORITHMS=RS256

# Generate for production with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
INTERNAL_WORKER_TOKEN=zylora-worker-development-token

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Leave S3 fields blank to use local development storage.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
STORAGE_LOCAL_PATH=./storage
MAX_UPLOAD_BYTES=10000000

EMAIL_PROVIDER=console
EMAIL_FROM=notifications@zylora.local
RESEND_API_KEY=

SENTRY_DSN=
LOG_LEVEL=INFO
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

# Production identity provider (OIDC authorization code + PKCE)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_AUTHORIZATION_URL=
AUTH_TOKEN_URL=
AUTH_END_SESSION_URL=
AUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

PAYMENT_CURRENCY=INR
USD_INR_RATE=84.00
MALWARE_SCAN_PROVIDER=none
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
S3_SERVER_SIDE_ENCRYPTION=AES256
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
ALERT_WEBHOOK_URL=
LEGAL_ENTITY_NAME=Zylora
LEGAL_CONTACT_EMAIL=
LEGAL_BUSINESS_ADDRESS=
LEGAL_JURISDICTION=India
REFUND_WINDOW_DAYS=7
