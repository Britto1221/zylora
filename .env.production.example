ENVIRONMENT=production
APP_NAME=Zylora
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGIN=https://zylora.example.com
PUBLIC_API_URL=https://api.zylora.example.com/api/v1

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/zylora?sslmode=require
REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0

# OIDC/JWT provider
AUTH_ISSUER=https://YOUR_AUTH_PROVIDER/
AUTH_AUDIENCE=zylora-api
AUTH_JWKS_URL=https://YOUR_AUTH_PROVIDER/.well-known/jwks.json
AUTH_ALGORITHMS=RS256
SUPER_ADMIN_EMAILS=owner@example.com

# Generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

SENTRY_DSN=
LOG_LEVEL=INFO
TRUSTED_HOSTS=zylora.example.com,api.zylora.example.com
