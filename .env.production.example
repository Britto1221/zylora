ENVIRONMENT=production
APP_NAME=Zylora

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/zylora?sslmode=require
REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0
WEB_ORIGIN=https://app.example.com
PUBLIC_API_URL=https://api.example.com/api/v1
API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_APP_URL=https://app.example.com

AUTH_ISSUER=https://YOUR_IDENTITY_PROVIDER/
AUTH_AUDIENCE=zylora-api
AUTH_JWKS_URL=https://YOUR_IDENTITY_PROVIDER/.well-known/jwks.json
AUTH_ALGORITHMS=RS256
SUPER_ADMIN_EMAILS=owner@example.com
DEV_AUTH_SECRET=
DEV_ADMIN_PASSWORD=

ENCRYPTION_KEY=
INTERNAL_WORKER_TOKEN=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
STORAGE_LOCAL_PATH=/app/storage
MAX_UPLOAD_BYTES=10000000

EMAIL_PROVIDER=resend
EMAIL_FROM=notifications@yourdomain.com
RESEND_API_KEY=

SENTRY_DSN=
LOG_LEVEL=INFO
TRUSTED_HOSTS=app.example.com,api.example.com,*.your-client-domain.com
