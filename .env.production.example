ENVIRONMENT=production
APP_NAME=Zylora
WEB_ORIGIN=https://app.yourdomain.com
PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/zylora?sslmode=verify-full
REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0

AUTH_ISSUER=https://YOUR_IDP/
AUTH_AUDIENCE=zylora-api
AUTH_JWKS_URL=https://YOUR_IDP/.well-known/jwks.json
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_AUTHORIZATION_URL=https://YOUR_IDP/authorize
AUTH_TOKEN_URL=https://YOUR_IDP/oauth/token
AUTH_END_SESSION_URL=
AUTH_REDIRECT_URI=https://app.yourdomain.com/api/auth/callback
AUTH_ALGORITHMS=RS256
SUPER_ADMIN_EMAILS=YOUR_REAL_VERIFIED_EMAIL

ENCRYPTION_KEY=
INTERNAL_WORKER_TOKEN=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYMENT_CURRENCY=INR
USD_INR_RATE=84.00

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_SERVER_SIDE_ENCRYPTION=AES256
MALWARE_SCAN_PROVIDER=clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
ALERT_WEBHOOK_URL=
LOG_LEVEL=INFO
TRUSTED_HOSTS=app.yourdomain.com,api.yourdomain.com

LEGAL_ENTITY_NAME=Zylora
LEGAL_CONTACT_EMAIL=
LEGAL_BUSINESS_ADDRESS=
LEGAL_JURISDICTION=India
REFUND_WINDOW_DAYS=7
